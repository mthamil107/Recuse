# Live-server experiment harness — contains real host IP / username. Never publish.
experiments/openfga/
experiments/**/_lib.py

# Server credential files (defensive; these live outside the repo anyway)
*.env
*.pem
*.key

# Phase 2 experiment secrets + raw transcripts (API keys, real host, trial logs)
**/secrets.local.json
experiments/phase2/secrets.local.json
experiments/phase2/results/
experiments/phase2/raw/

# Compiled proxy binary — built from source via adapters/postgres/README.md.
adapters/postgres/bin/
# Compiled webhook binary — built from source via adapters/kubernetes/README.md.
adapters/kubernetes/bin/
# Generated TLS material from hack/gen-certs.sh (never commit private keys).
adapters/kubernetes/hack/certs/
*.exe

# LaTeX build artifacts + the portable tectonic engine (not source)
paper/tectonic.zip
paper/tectonic_bin/
paper/*.aux
paper/*.log
paper/*.out
paper/*.bbl
paper/*.blg
paper/*.toc
paper/arxiv-submission.zip

# Debian build artifacts (dpkg-buildpackage writes these into packaging/)
packaging/*.deb
packaging/*.buildinfo
packaging/*.changes
packaging/deb/debian/.debhelper/
packaging/deb/debian/recuse-ssh/
packaging/deb/debian/files
packaging/deb/debian/*.substvars
packaging/deb/debian/*.debhelper.log

# Python
__pycache__/
*.pyc
.venv/
venv/

# OS / editor
Thumbs.db
.DS_Store
.vscode/
.idea/
