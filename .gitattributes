# The SSH adapter is deployed on Linux. Force LF so cloned scripts run on Ubuntu
# regardless of the cloner's core.autocrlf setting.
*.sh           text eol=lf
*.snippet      text eol=lf
banner.txt     text eol=lf
*.md           text eol=lf
*.go           text eol=lf
go.mod         text eol=lf
go.sum         text eol=lf
*.service      text eol=lf
*.tex          text eol=lf
*.bib          text eol=lf

# Debian packaging: maintainer scripts and helpers are extensionless shell
# scripts that MUST stay LF so dpkg/sh run them correctly on Ubuntu.
packaging/deb/debian/postinst        text eol=lf
packaging/deb/debian/prerm           text eol=lf
packaging/deb/debian/postrm          text eol=lf
packaging/deb/debian/rules           text eol=lf
packaging/deb/debian/control         text eol=lf
packaging/deb/debian/changelog       text eol=lf
packaging/deb/debian/copyright       text eol=lf
packaging/deb/debian/conffiles       text eol=lf
packaging/deb/debian/source/format   text eol=lf
packaging/deb/debian/*.install       text eol=lf
packaging/deb/usr/sbin/recuse-pam-hook        text eol=lf
packaging/deb/usr/share/recuse/render-banner  text eol=lf
*.conf         text eol=lf
*.template     text eol=lf
*.example      text eol=lf

# The compiled paper is binary.
*.pdf          binary

# Treat the demo recording as binary (never line-ending-converted or diffed).
*.gif          binary
